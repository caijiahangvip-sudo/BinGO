  "scripts": {
    "postinstall": "cd packages/mathml2omml && npm run build && cd ../pptxgenjs && npm run build",
    "dev": "next dev --webpack --port 4000",
    "dev:clean": "rm -rf .next/dev && next dev --webpack --port 4000",
    "dev:bingo": "powershell -ExecutionPolicy Bypass -File scripts/start-bingo.ps1",
    "dev:bingo:clean": "powershell -ExecutionPolicy Bypass -File scripts/start-bingo.ps1 -CleanNextCache",
    "dev:bingo:silent": "wscript scripts/start-bingo-silent.vbs",
    "dev:bingo:silent:clean": "wscript scripts/start-bingo-silent-clean.vbs",
    "prebuild": "node -e \"const fs=require('fs'); for(const p of ['desktop-dist','src-tauri/target/release/server','src-tauri/target/release/binaries']) fs.rmSync(p,{recursive:true,force:true})\"",
    "build": "next build",
    "desktop:prepare": "node scripts/prepare-desktop.mjs",
    "desktop:configure-release": "node scripts/configure-desktop-release.mjs",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:ci": "pnpm build && pnpm desktop:prepare && tauri build",
    "start": "next start --port 4000",
    "lint": "eslint",
    "check": "prettier . --check",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
