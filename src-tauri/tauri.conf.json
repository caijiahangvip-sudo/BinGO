{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BinGO",
  "version": "0.3.9",
  "identifier": "app.bingo.desktop",
  "build": {
    "frontendDist": "../desktop-loader",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm desktop:prepare"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "BinGO",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: http://127.0.0.1:*; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* https:; img-src 'self' asset: http://asset.localhost data: blob: http: https:; media-src 'self' asset: blob: http: https:; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../desktop-dist/server": "server",
      "binaries/node.exe": "binaries/node.exe"
    },
    "createUpdaterArtifacts": "v1Compatible",
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerHooks": "windows/installer-hooks.nsh",
        "template": "nsis/installer.nsi"
      }
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/caijiahangvip-sudo/BinGO/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2NEQ3MjVDNzU0ODYxMjIKUldRaVlVaDFYSEpOWm5rTmQvaTd3UzJsTVhtQytSVWJOSmRBcWlMTTNNcmRySjlDc0RjRG9kMkwK"
    }
  }
}
