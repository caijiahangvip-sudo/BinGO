{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BinGO",
  "version": "0.1.1",
  "identifier": "app.bingo.desktop",
  "build": {
    "frontendDist": "../desktop-loader",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm desktop:prepare"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BinGO",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: http://127.0.0.1:*; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* https:; img-src 'self' asset: http://asset.localhost data: blob: http: https:; media-src 'self' asset: blob: http: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": {
      "../desktop-dist/server": "server",
      "binaries/node.exe": "binaries/node.exe"
    },
    "createUpdaterArtifacts": "v1Compatible",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/caijiahangvip-sudo/BinGO/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGNThCQzlERTQ3M0I4QTMKUldTanVIUGtuYnhZTHpuRDZLZ21XOTZkUkU5ZTgrYUFSRGphWHRjQkhHbUtCTi8xa1RVN3YrUVgK"
    }
  }
}
