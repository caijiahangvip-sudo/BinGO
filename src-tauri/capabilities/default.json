{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-desktop-system-proxy",
    "allow-start-bingo-server",
    "process:allow-restart",
    "updater:default"
  ]
}
